{
	"schemaVersion": 1,
	"id": "showmyfps",
	"version": "${version}",
	"name": "Show My FPS",
	"description": "A Simple Yet Extremely Customizable FPS Display Mod That Has Minimal Performance Impact and Is Designed to Be Easy to Use.",
	"authors": [
		"Indru Dev"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/show-my-fps/",
		"sources": "https://github.com/indru-dev/show-my-fps"
	},
	"license": "MIT",
	"icon": "assets/showmyfps/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"mod.me.indrudev.dev.showmyfps.ignoreSMF"
		],
		"client": [
			"mod.me.indrudev.dev.showmyfps.client.SMF"
		],
		"modmenu": [
			"mod.me.indrudev.dev.showmyfps.client.ModMenuImpl"
		]
	},
	"mixins": [
		"showmyfps.mixins.json",
		{
			"config": "showmyfps.client.mixins.json",
			"environment": "client"
		}
	],
	"custom": {
		"modmenu": {
			"badges": ["utility"],
			"update_checker": true
		}
	},
	"suggests": {
		"modmenu": "11.0.4"
	},
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~1.21",
		"java": ">=21",
		"fabric-api": "*",
		"yet_another_config_lib_v3": ">=3.6.1+1.21-fabric",
		"modmenu": ">=11.0.2"
	}
}